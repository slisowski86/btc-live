# Copy this file to  secrets.env  and fill in your credentials.
# secrets.env is git-ignored - NEVER commit it or share these values.
# Keep each value on its own line with NO trailing comment (comments only on their own #-lines).

# --- Kraken Futures DEMO (full futures: shorts + leverage, fake money) ---
# Create at demo-futures.kraken.com -> Settings -> API Keys. Used by `paper_trader.py --testnet`.
KRAKEN_FUTURES_DEMO_KEY=your_kraken_demo_key
KRAKEN_FUTURES_DEMO_SECRET=your_kraken_demo_secret

# --- Kraken Futures REAL (futures trading) ---
# Create at futures.kraken.com -> Settings -> API Keys. Used by `paper_trader.py --live`.
KRAKEN_FUTURES_KEY=your_real_kraken_futures_key
KRAKEN_FUTURES_SECRET=your_real_kraken_futures_secret

# --- LIVE safety switch ---
# *** REAL MONEY *** - real orders are only placed when you run --live AND set this to exactly YES.
# Leave NO for paper / demo only.
LIVE_CONFIRM=NO

# --- Email alerts (live monitoring + reports) ---
# Trade / error / crash / daily-summary emails. Gmail: turn on 2-Step Verification, then create
# an APP PASSWORD (Google Account -> Security -> App passwords) and paste it as SMTP_PASSWORD.
EMAIL_ENABLED=1
SMTP_HOST=smtp.gmail.com
# SMTP_PORT: 587 = STARTTLS (default), 465 = SSL
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16_char_app_password
# EMAIL_FROM is optional; defaults to SMTP_USER
EMAIL_FROM=you@gmail.com
# EMAIL_TO: comma-separate for several recipients
EMAIL_TO=you@gmail.com

# --- Claude daily strategy review (optional) ---
# If set, the daily summary asks Claude to review performance and appends notes ONLY when it
# flags something. Leave blank to skip. Needs:  pip install anthropic
ANTHROPIC_API_KEY=
